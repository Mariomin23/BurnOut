{"nodes": [{"id": "readme_burnout_app", "label": "BurnOut \u2014 Smart Gym Routine Generator", "file_type": "document", "source_file": "README.md", "source_location": null, "source_url": "https://burnout.minuesa.es", "captured_at": null, "author": "Mario Minuesa (@Mariomin23)", "contributor": null}, {"id": "readme_layered_architecture", "label": "Layered Backend Architecture (Routes \u2192 Controllers \u2192 Services \u2192 Repositories)", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Business logic lives in services and is framework-agnostic; dependency injection happens at composition time in routineRoutes.ts, keeping each layer independently testable."}, {"id": "readme_repository_pattern", "label": "Repository Pattern (IExerciseRepository)", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Exercises are served from static JSON behind an IExerciseRepository interface so swapping in MongoDB (Phase 3) means writing one new repository class; the service layer does not change \u2014 a painless DB migration by design."}, {"id": "readme_zod_validation", "label": "Zod Input Validation at Every Endpoint", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every endpoint validates its payload against a schema (userProfile.schema.ts) before it reaches business logic, replacing manual field checks."}, {"id": "readme_pure_function_core", "label": "Pure Functions for Testability", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Core logic (e.g. frontend/src/lib/history.ts) is written as pure functions precisely so it can be tested without mocking React or Express; 34 Vitest tests cover generation, progression and history logic."}, {"id": "readme_custom_hooks", "label": "Custom Hooks for Separation of Concerns (useWorkout, useStreak, useRestTimer, useHistory)", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Custom hooks keep App.tsx declarative and make each concern independently testable."}, {"id": "readme_double_progression", "label": "Double Progression (more reps \u2192 more weight)", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_offline_mode", "label": "Offline Mode via LocalStorage", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The active routine survives refreshes and connection loss via LocalStorage, with emergency client-side generation if the server is unreachable \u2014 the app must work inside a gym with bad connectivity."}, {"id": "readme_reroll", "label": "Re-roll Mechanic (swap exercise, same muscle group)", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_suggested_weights", "label": "Smart Starting Weights (bodyweight/sex/experience strength ratios, 2.5 kg rounding)", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_api_generate", "label": "POST /api/routines/generate", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "rea