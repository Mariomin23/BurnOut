{"nodes": [{"id": "docs_superpowers_specs_2026_06_30_burnout_improvements_design_fase_1_5_design", "label": "Fase 1.5 Improvements Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-30-burnout-improvements-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_06_30_burnout_improvements_design_confirmmodal", "label": "ConfirmModal (replaces window.confirm)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-30-burnout-improvements-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "window.confirm blocks the UI thread on mobile and does not respect the app theme; a custom glass modal with danger action fixes both."}, {"id": "docs_superpowers_specs_2026_06_30_burnout_improvements_design_skeleton_loader", "label": "ExerciseCardSkeleton with Shimmer Animation", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-30-burnout-improvements-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Mirrors the real ExerciseCard layout (header + 3 set rows) during /generate fetch instead of a pulse spinner, reducing perceived latency."}, {"id": "docs_superpowers_specs_2026_06_30_burnout_improvements_design_difficulty_filtering", "label": "Difficulty Filtering in Routine Generation", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-30-burnout-improvements-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "beginner \u2192 only beginner, intermediate \u2192 beginner|intermediate, advanced \u2192 all; if the filtered pool has fewer than 3 candidates for a muscle group it widens to the next level \u2014 the system never returns an empty routine."}, {"id": "docs_superpowers_specs_2026_06_30_burnout_improvements_design_streak_consecutive_days", "label": "Real Consecutive-Days Streak (fit_poke_streak_v2)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-30-burnout-improvements-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Compares date only (no time) to avoid the midnight edge case; uses a new localStorage key (fit_poke_streak_v2) to avoid conflict with the previous raw-number format; streak breaks if a day is skipped."}, {"id": "docs_superpowers_specs_2026_06_30_burnout_improvements_design_hook_extraction", "label": "Hook Extraction from Monolithic App.tsx (useWorkout, useStreak, useRestTimer)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-30-burnout-improvements-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "App.tsx was a 415-line monolith; extracting three hooks reduces it to ~80-130 lines of view routing and makes state logic independently testable."}, {"id": "docs_superpowers_specs_2026_06_30_burnout_improvements_design_userprofile_schema", "label": "UserProfileSchema (Zod) for API Payload Validation", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-30-burnout-improvements-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Controller validates before calling the service; invalid input returns 400 with structured ZodError details instead of crashing."}, {"id": "docs_superpowers_specs_2026_06_30_burnout_improvements_design_crypto_randomuuid", "label": "crypto.randomUUID() for Routine IDs", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-30-burnout-improvements-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Re