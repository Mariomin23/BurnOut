{"nodes": [{"id": "docs_superpowers_specs_2026_07_08_fase_2b_graficos_design_fase_2b_design", "label": "Fase 2B Design Spec \u2014 Extended Profile and Progress Charts", "file_type": "document", "source_file": "docs/superpowers/specs/2026-07-08-fase-2b-graficos-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_08_fase_2b_graficos_design_svg_progress_chart", "label": "Pure SVG ProgressChart (no chart library)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-08-fase-2b-graficos-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hand-rolled SVG line chart (~320x150 viewBox, emerald\u2192sky gradient from Ember Ledger) keeps the bundle small (ultra-fast-load principle) and gives total style control."}, {"id": "docs_superpowers_specs_2026_07_08_fase_2b_graficos_design_history_view", "label": "HistoryView (aggregate stats + per-exercise chart + workout list)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-08-fase-2b-graficos-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "100% frontend: the history already lives in localStorage via useHistory; without auth (Fase 3) history is per-device, so the backend does not participate."}, {"id": "docs_superpowers_specs_2026_07_08_fase_2b_graficos_design_local_state_navigation", "label": "Local-State Navigation (view: home | history, no router)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-08-fase-2b-graficos-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Two views do not justify adding a router dependency; navigation is a local state field in App."}, {"id": "docs_superpowers_specs_2026_07_08_fase_2b_graficos_desig