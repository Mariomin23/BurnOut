{"nodes": [{"id": "docs_superpowers_specs_2026_07_08_fase_3_infraestructura_design_fase_3_design", "label": "Fase 3 Design Spec \u2014 MongoDB, JWT Auth and PWA", "file_type": "document", "source_file": "docs/superpowers/specs/2026-07-08-fase-3-infraestructura-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_08_fase_3_infraestructura_design_hybrid_exercise_repository", "label": "HybridExerciseRepository (Mongo with static-JSON fallback)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-08-fase-3-infraestructura-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Uses Mongo when connected and the collection has data, otherwise falls back to static JSON; the service layer did not change a single line \u2014 the swap promised by the repository pattern."}, {"id": "docs_superpowers_specs_2026_07_08_fase_3_infraestructura_design_idempotent_seed", "label": "Idempotent Seed \u2014 JSON stays the source of truth (syncExercisesToDb)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-08-fase-3-infraestructura-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "On every startup with a connection, idempotent upserts from exercises.json update the DB: a deploy with new exercises updates the database on its own; manual npm run seed also exists."}, {"id": "docs_superpowers_specs_2026_07_08_fase_3_infraestructura_design_jwt_auth", "label": "Stateless JWT Auth (30-day HS256, bcryptjs salt 10)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-08-fase-3-infraestructura-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "No refresh tokens: for a personal gym app, monthly re-login is acceptable. Login and register return uniform 401/409 without leaking which emails exist."}, {"id": "docs_superpowers_specs_2026_07_08_fase_3_infraestructura_design_cloud_history_mirror", "label": "Cloud History as Mirror of Local (mergeHistories, local wins)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-08-fase-3-infraestructura-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "localStorage remains the primary truth so the app works 100% anonymous and offline; on login remote history is merged (dedup by id, local wins, ordered by date, cap 100) and every local change is uploaded whole via PUT to a single per-user document \u2014 simple, idempotent, no server-side merge conflicts."}, {"id": "docs_superpowers_specs_2026_07_08_fase_3_infraestructura_design_requiredb_503", "label": "requireDb Middleware (503 instead of crash without DB)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-08-fase-3-infraestructura-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Auth/history endpoints return 503 when the DB is unavailable so the Render deploy keeps working even if MONGO_URI/JWT_SECRET env vars are missing."}, {"id": "docs_superpowers_specs_2026_07_08_fase_3_infraestructura_design_pwa", "label": "Installable PWA (vite-plugin-pwa, generateSW, autoUpdate)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-08-fase-3-infraestructura-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Precaches the full build plus Google Fonts at runtime; the API is deliberately NOT cached because the offline routine mode is already solved by useWorkout's local fallback."}], "edges": [{"source": "docs_superpowers_specs_2026_07_08_fase_3_infraestructura_design_fase_3_design", "target": "contextburn_fase_3_infraestructura", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-08-fase-3-infraestructura-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_07_08_fase_3_infraestructura_design_fase_3_design", "target": "docs_superpowers_specs_2026_07_08_fase_3_infraestructura_design_hybrid_exercise_repository", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-08-fase-3-infraestructura-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_07_08_fase_3_infraestructura_design_fase_3_design", "target": "docs_superpowers_specs_2026_07_08_fase_3_infraestructura_design_idempotent_seed", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-08-fase-3-infraestructura-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_07_08_fase_3_infraestructura_design_fase_3_design", "target": "docs_superpowers_specs_2026_07_08_fase_3_infraestructura_design_jwt_auth", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-08-fase-3-infraestructura-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_07_08_fase_3_infraestructura_design_fase_3_design", "target": "docs_superpowers_specs_2026_07_08_fase_3_infraestructura_design_cloud_history_mirror", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-08-fase-3-infraestructura-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_07_08_fase_3_infraestructura_design_fase_3_design", "target": "docs_superpowers_specs_2026_07_08_fase_